# ===========================================
# Starlink Bill Payment Service - Environment
# Independent Third-Party Billing Assistance
# ===========================================

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=starlink_user
DB_PASSWORD=starlink_pass
DB_NAME=starlink_billing
DATABASE_URL=postgresql://starlink_user:starlink_pass@localhost:5432/starlink_billing

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Backend
BACKEND_PORT=3001
NODE_ENV=development
BACKEND_URL=http://localhost:3001

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# JWT
JWT_SECRET=your-jwt-secret-change-this
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (for storing sensitive settings)
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=4096

# Facebook Messenger
FB_PAGE_ACCESS_TOKEN=your-page-access-token
FB_VERIFY_TOKEN=your-verify-token
FB_APP_SECRET=your-app-secret
FB_APP_ID=your-app-id
FB_WEBHOOK_URL=https://yourdomain.com/api/v1/messenger/webhook

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id
TELEGRAM_ENABLED=true

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/png,image/jpeg,image/jpg,application/pdf

# Admin
ADMIN_DEFAULT_EMAIL=admin@example.com
ADMIN_DEFAULT_PASSWORD=change-this-password

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Backup
BACKUP_ENABLED=false
BACKUP_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=30
